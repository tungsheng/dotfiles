#!/bin/bash
# Dotfiles installer - bash 3.2+ compatible
# shellcheck disable=SC2034
set -e
trap 'echo; exit 130' INT

DOTFILES_DIR="$(cd "$(dirname "$0")" && pwd)"
DOTFILES_LIB_DIR="$DOTFILES_DIR/scripts/dot"

# shellcheck disable=SC1091
source "$DOTFILES_LIB_DIR/config.sh"
# shellcheck disable=SC1091
source "$DOTFILES_LIB_DIR/ui.sh"
# shellcheck disable=SC1091
source "$DOTFILES_LIB_DIR/helpers.sh"
# shellcheck disable=SC1091
source "$DOTFILES_LIB_DIR/operations.sh"
# shellcheck disable=SC1091
source "$DOTFILES_LIB_DIR/commands.sh"

main() {
    local cmd=""

    while [ $# -gt 0 ]; do
        case "$1" in
            install|update|uninstall|health|status) cmd="$1"; shift ;;
            -n|--dry-run) DRY_RUN=true; shift ;;
            -v|--verbose) VERBOSE=true; shift ;;
            -h|--help) print_usage; exit 0 ;;
            *) log_fail "Unknown: $1"; echo; print_usage; exit 1 ;;
        esac
    done

    if [ -z "$cmd" ]; then
        print_usage
        exit 0
    fi

    case "$cmd" in
        install)   cmd_install ;;
        update)    cmd_update ;;
        uninstall) cmd_uninstall ;;
        health)    cmd_health ;;
        status)    cmd_status ;;
    esac
}

main "$@"
